generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model EwasteRequest {
  id        Int      @id @default(autoincrement())
  jenis     String
  jumlah    Int
  lokasi    String
  status    String   @default("Baru")
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?   // ✅ optional (aman buat user lama)
  role      Role      @default(CUSTOMER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
enum Role {
  CUSTOMER
  COLLECTOR
}
